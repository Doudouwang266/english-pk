{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd packages/client && npx vite build && cd ../server && npm install"
  },
  "deploy": {
    "startCommand": "cd packages/server && npx tsx src/index.ts",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 10
  }
}
